{
  "name": "@awesome-agent/agent-core",
  "version": "0.5.0",
  "description": "Agentic loop core library — provider-agnostic, server-independent",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js",
      "default": "./dist/llm/index.js"
    },
    "./tool": {
      "types": "./dist/tool/index.d.ts",
      "import": "./dist/tool/index.js",
      "default": "./dist/tool/index.js"
    },
    "./hook": {
      "types": "./dist/hook/index.d.ts",
      "import": "./dist/hook/index.js",
      "default": "./dist/hook/index.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js",
      "default": "./dist/context/index.js"
    },
    "./skill": {
      "types": "./dist/skill/index.d.ts",
      "import": "./dist/skill/index.js",
      "default": "./dist/skill/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "default": "./dist/agent/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js",
      "default": "./dist/memory/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "default": "./dist/storage/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "default": "./dist/mcp/index.js"
    },
    "./loop": {
      "types": "./dist/loop/index.d.ts",
      "import": "./dist/loop/index.js",
      "default": "./dist/loop/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "agentic",
    "llm",
    "ai",
    "openai",
    "tool-use",
    "function-calling",
    "mcp",
    "model-context-protocol",
    "orchestrator"
  ],
  "author": "Kaan Bingol <kaanbingol@outlook.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/awesome-agent/awesome-agent-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/awesome-agent/awesome-agent-sdk#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
