{
  "name": "@awesome-agent/ui",
  "version": "0.1.0",
  "description": "Headless React hooks for @awesome-agent — zero styling, pluggable transport",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "author": "Kaan Bingol <kaanbingol@outlook.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/awesome-agent/awesome-agent-sdk.git",
    "directory": "packages/ui"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
